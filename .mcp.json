{
  "mcpServers": {
    "orbitnest": {
      "command": "/Users/ali/.nvm/versions/node/v22.21.1/bin/npx",
      "args": ["-y", "github:mahtab-ali/orbitnest_mcp"],
      "env": {
        "ORBITNEST_API_URL": "https://api.orbitnest.io",
        "ORBITNEST_API_BASE_PATH": "/api",
        "MCP_SERVER_NAME": "orbitnest-studio",
        "MCP_SERVER_VERSION": "1.0.0",
        "LOG_LEVEL": "info",
        "ENABLE_SQL_GUARD": "true",
        "REQUIRE_DESTRUCTIVE_CONFIRMATION": "true",
        "BLOCK_AUTH_TABLE_MUTATIONS": "true",
        "SCHEMA_CACHE_TTL": "300000",
        "TOKEN_REFRESH_THRESHOLD": "60000",
        "PATH": "/Users/ali/.nvm/versions/node/v22.21.1/bin:/usr/local/bin:/usr/bin:/bin"
      }
    }
  }
}
