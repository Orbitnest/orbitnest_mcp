{
  "name": "@orbitnest/mcp-server",
  "version": "1.1.0",
  "description": "Model Context Protocol server for OrbitNest Studio",
  "main": "dist/index.js",
  "bin": {
    "orbitnest-mcp": "dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts"
  },
  "files": [
