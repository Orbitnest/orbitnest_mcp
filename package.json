  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0"
  },
  "keywords": ["mcp", "orbitnest", "model-context-protocol", "ai"],
  "author": "OrbitNest Team",
  "license": "MIT"
