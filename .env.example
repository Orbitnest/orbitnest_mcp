# OrbitNest Backend Configuration
# ORBITNEST_API_URL must point at the OrbitNest API whose Studio hosts the
# OAuth callback page — used by the orbitnest_login (Google/GitHub/Apple) tool.
ORBITNEST_API_URL=https://api.orbitnest.io
ORBITNEST_API_BASE_PATH=/api

# Authentication
# Sign in at runtime with orbitnest_admin_signin (email + password) or
# orbitnest_login (Google/GitHub/Apple via browser). Tokens are stored in
# ~/.orbitnest/credentials.json — no token needs to be set here.

# MCP Server Configuration
MCP_SERVER_NAME=orbitnest-studio
MCP_SERVER_VERSION=1.0.0
LOG_LEVEL=info

# Workspace Configuration (optional, can be detected)
DEFAULT_PROJECT_ID=
DEFAULT_ENVIRONMENT=development

# Safety Configuration
ENABLE_SQL_GUARD=true
REQUIRE_DESTRUCTIVE_CONFIRMATION=true
BLOCK_AUTH_TABLE_MUTATIONS=true

# Cache Configuration
SCHEMA_CACHE_TTL=300000
TOKEN_REFRESH_THRESHOLD=60000
